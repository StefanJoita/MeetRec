# ============================================================
# .env.example — TEMPLATE pentru configurare
# ============================================================
# INSTRUCȚIUNI:
#   1. Copiază acest fișier: cp .env.example .env
#   2. Editează .env cu valorile reale
#   3. NICIODATĂ nu commita .env în Git!
# ============================================================

# --- POSTGRESQL ---
# Baza de date principală a aplicației
POSTGRES_HOST=postgres          # numele containerului Docker
POSTGRES_PORT=5432
POSTGRES_DB=meeting_transcriber
POSTGRES_USER=mt_user
POSTGRES_PASSWORD=change_me_in_production   # ← SCHIMBĂ ASTA!

# URL complet (construit din variabilele de mai sus)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://mt_user:change_me_in_production@postgres:5432/meeting_transcriber

# --- REDIS ---
# Queue pentru joburi de transcriere
REDIS_HOST=redis                # numele containerului Docker
REDIS_PORT=6379
REDIS_URL=redis://redis:6379
# Numele cozii (poți schimba dacă ai mai multe cozi)
REDIS_TRANSCRIPTION_QUEUE=transcription_jobs

# --- STORAGE (NFS/NAS) ---
# Unde sunt stocate fișierele audio pe disc
AUDIO_STORAGE_PATH=/data/processed  # calea din container
INBOX_PATH=/data/inbox              # unde vin fișierele noi
EXPORT_PATH=/data/exports           # unde se salvează exporturile
# Dimensiunea maximă a unui fișier audio (în bytes): 500MB
MAX_FILE_SIZE_BYTES=524288000

# --- STT WORKER (Whisper) ---
# Modelul Whisper: tiny/base/small/medium/large
# Compromis: larger = mai precis dar mai lent și mai mult RAM
# Recomandare pentru română: medium (bun echilibru)
WHISPER_MODEL=medium
# Limba principală (ajută Whisper să fie mai precis)
WHISPER_PRIMARY_LANGUAGE=ro
# Calea unde sunt descărcate modelele (offline!)
WHISPER_MODEL_PATH=/app/models
# Câte joburi procesează simultan (1 dacă nu ai GPU)
STT_WORKER_CONCURRENCY=1

# --- API BACKEND ---
# Portul pe care ascultă API-ul (intern, nu expus direct)
API_PORT=8080
# Cheia secretă pentru JWT tokens (autentificare)
# Generează una puternică: openssl rand -hex 32
JWT_SECRET_KEY=change_me_to_a_random_32_char_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480          # 8 ore (o zi de lucru)

# --- NGINX (Reverse Proxy) ---
# Portul HTTPS expus utilizatorilor
NGINX_HTTPS_PORT=443
# Domeniul sau IP-ul serverului
SERVER_NAME=meeting-transcriber.local

# --- AUDIT & RETENȚIE ---
# Câte zile să păstrăm înregistrările (legal: minim 3 ani = 1095)
RETENTION_DAYS=1095
# Câte zile să păstrăm logurile de audit
AUDIT_LOG_RETENTION_DAYS=2190   # 6 ani

# --- MONITORING (Grafana/Loki) ---
GRAFANA_ADMIN_PASSWORD=change_me_grafana
LOKI_PORT=3100
GRAFANA_PORT=3000

# --- MEDIU ---
# "development" sau "production"
# În dev: mai multe loguri, fără HTTPS forțat
APP_ENV=development
LOG_LEVEL=INFO
