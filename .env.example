# ============================================================
# .env.example — TEMPLATE pentru configurare
# ============================================================
# INSTRUCȚIUNI:
#   1. Copiază acest fișier: cp .env.example .env
#   2. Editează .env cu valorile reale
#   3. NICIODATĂ nu commita .env în Git!
# ============================================================

# --- POSTGRESQL ---
POSTGRES_HOST=postgres          # numele containerului Docker
POSTGRES_PORT=5432
POSTGRES_DB=meeting_transcriber
POSTGRES_USER=mt_user
POSTGRES_PASSWORD=change_me_in_production   # ← SCHIMBĂ ASTA!

# URL complet pentru SQLAlchemy async
# IMPORTANT: "postgresql+asyncpg://" (nu "postgresql://")
# Fără "+asyncpg" → eroare la startup: "Could not load backend 'asyncpg'"
DATABASE_URL=postgresql+asyncpg://mt_user:change_me_in_production@postgres:5432/meeting_transcriber

# --- REDIS ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379
REDIS_TRANSCRIPTION_QUEUE=transcription_jobs

# --- STORAGE (NFS/NAS) ---
AUDIO_STORAGE_PATH=/data/processed
INBOX_PATH=/data/inbox
EXPORT_PATH=/data/exports
MAX_FILE_SIZE_BYTES=524288000   # 500MB

# --- STT WORKER (Whisper) ---
WHISPER_MODEL=medium
WHISPER_PRIMARY_LANGUAGE=ro
WHISPER_MODEL_PATH=/app/models
STT_WORKER_CONCURRENCY=1

# --- API BACKEND ---
API_PORT=8080
# IMPORTANT: Generează o cheie secretă UNICĂ cu comanda de mai jos și înlocuiește VALOAREA_GENERATA:
#   python -c "import secrets; print(secrets.token_hex(32))"
# NICIODATĂ nu folosi valoarea din acest fișier în producție!
JWT_SECRET_KEY=your-secret-key-min-32-chars-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480          # 8 ore (o zi de lucru)

# --- NGINX (Reverse Proxy) ---
NGINX_HTTPS_PORT=443
SERVER_NAME=meeting-transcriber.local

# --- AUDIT & RETENȚIE ---
RETENTION_DAYS=1095             # 3 ani
AUDIT_LOG_RETENTION_DAYS=2190   # 6 ani

# --- MEDIU ---
APP_ENV=development
LOG_LEVEL=INFO
