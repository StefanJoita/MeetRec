# ============================================================
# .env — Configurare locală pentru development
# ============================================================
# NICIODATĂ nu commita acest fișier în Git!
# ============================================================

# --- POSTGRESQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=meeting_transcriber
POSTGRES_USER=mt_user
POSTGRES_PASSWORD=meetrec_dev_2024

# URL complet pentru SQLAlchemy async
DATABASE_URL=postgresql+asyncpg://mt_user:meetrec_dev_2024@postgres:5432/meeting_transcriber

# --- REDIS ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379
REDIS_TRANSCRIPTION_QUEUE=transcription_jobs

# --- STORAGE (NFS/NAS) ---
AUDIO_STORAGE_PATH=/data/processed
INBOX_PATH=/data/inbox
EXPORT_PATH=/data/exports
MAX_FILE_SIZE_BYTES=524288000

# --- STT WORKER (Whisper) ---
WHISPER_MODEL=medium
WHISPER_PRIMARY_LANGUAGE=ro
WHISPER_MODEL_PATH=/app/models
STT_WORKER_CONCURRENCY=1

# --- API BACKEND ---
API_PORT=8080
JWT_SECRET_KEY=meetrec-dev-jwt-secret-key-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# --- NGINX ---
NGINX_HTTPS_PORT=443
SERVER_NAME=meeting-transcriber.local

# --- AUDIT & RETENȚIE ---
RETENTION_DAYS=1095
AUDIT_LOG_RETENTION_DAYS=2190

# --- MONITORING ---
GRAFANA_ADMIN_PASSWORD=grafana_dev_2024
LOKI_PORT=3100
GRAFANA_PORT=3000

# --- MEDIU ---
APP_ENV=development
LOG_LEVEL=INFO
